{# Contenu onglet Inspecteur #}
<div class="pb-panel pb-panel--active" data-panel="inspector" data-page-builder-target="panel">

    {# Inspecteur : état par défaut #}
    <section class="pb-section" data-page-builder-target="inspectorPanelDefault">
        <div class="pb-section-body pb-section-body--muted">
            <p class="pb-empty-state">
                {% trans %}page.builder.inspector.placeholder{% endtrans %}
            </p>
        </div>
    </section>

    {# Container des accordéons #}
    <div class="pb-accordion-inspector accordion accordion-flush d-none" id="inspectorAccordion" data-page-builder-target="inspectorAccordionContainer">

        {# --- 1. BLOC --- #}
        <div class="accordion-item d-none" data-page-builder-target="inspectorPanelBlock">
            <h2 class="accordion-header" id="headingBlock">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseBlock" aria-expanded="false" aria-controls="collapseBlock">
                    <span data-page-builder-target="blockTitle">{% trans %}page.builder.inspector.block{% endtrans %}</span>
                </button>
            </h2>
            <div id="collapseBlock" class="accordion-collapse collapse" aria-labelledby="headingBlock" data-bs-parent="#inspectorAccordion">
                <div class="accordion-body pb-inspector-block-content">
                    <div class="mb-2">
                        <label class="form-label form-label-sm">{% trans %}page.builder.inspector.block.content{% endtrans %}</label>
                        <textarea
                            class="form-control form-control-sm"
                            rows="4"
                            placeholder="{{ 'page.builder.inspector.block.content_placeholder'|trans }}"
                            data-page-builder-target="blockContentInput"
                            data-action="input->page-builder#updateBlockContent"
                        ></textarea>
                    </div>
                </div>
            </div>
        </div>

        {# --- 2. COLUMN --- #}
        <div class="accordion-item d-none" data-page-builder-target="inspectorPanelColumn">
            <h2 class="accordion-header" id="headingColumn">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseColumn" aria-expanded="true" aria-controls="collapseColumn">
                    {% trans %}page.builder.inspector.column{% endtrans %}
                </button>
            </h2>
            <div id="collapseColumn" class="accordion-collapse collapse show" aria-labelledby="headingColumn" data-bs-parent="#inspectorAccordion">
                <div class="accordion-body">
                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1" for="column-horizontal-alignment">{% trans %}page.builder.inspector.column.horizontal_alignment{% endtrans %}</label>
                        <div class="d-flex gap-1">
                            <button type="button"
                                    class="pb-button pb-button--ghost flex-fill"
                                    data-alignment="left"
                                    data-page-builder-target="columnAlignmentButton"
                                    data-action="click->page-builder#updateColumnHorizontalAlignment"
                                    title="Aligné à gauche">
                                <i class="fas fa-align-left"></i>
                            </button>
                            <button type="button"
                                    class="pb-button pb-button--ghost flex-fill"
                                    data-alignment="center"
                                    data-page-builder-target="columnAlignmentButton"
                                    data-action="click->page-builder#updateColumnHorizontalAlignment"
                                    title="Centré">
                                <i class="fas fa-align-center"></i>
                            </button>
                            <button type="button"
                                    class="pb-button pb-button--ghost flex-fill"
                                    data-alignment="right"
                                    data-page-builder-target="columnAlignmentButton"
                                    data-action="click->page-builder#updateColumnHorizontalAlignment"
                                    title="Aligné à droite">
                                <i class="fas fa-align-right"></i>
                            </button>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1" for="column-link-type">{% trans %}page.builder.inspector.column.link_type{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="column-link-type"
                                data-page-builder-target="columnLinkTypeSelect"
                                data-action="change->page-builder#updateColumnLinkType">
                            <option value="">{% trans %}form.none{% endtrans %}</option>
                            <option value="url">{% trans %}page.builder.inspector.column.link_url{% endtrans %}</option>
                            <option value="page">{% trans %}page.builder.inspector.column.link_page_cms{% endtrans %}</option>
                            <option value="fixed">{% trans %}page.builder.inspector.column.link_page_fixed{% endtrans %}</option>
                        </select>
                    </div>
                    <div class="mb-2 d-none" data-page-builder-target="columnUrlInputContainer">
                        <label class="form-label form-label-sm d-block mb-1" for="column-url">{% trans %}page.builder.inspector.column.link_url{% endtrans %}</label>
                        <input type="text"
                               class="form-control form-control-sm"
                               id="column-url"
                               placeholder="https://..."
                               data-page-builder-target="columnUrlInput"
                               data-action="input->page-builder#updateColumnUrl">
                    </div>
                    <div class="mb-2 d-none" data-page-builder-target="columnPagePathSelectContainer">
                        <label class="form-label form-label-sm d-block mb-1" for="column-page-path">{% trans %}page.builder.inspector.column.link_page_cms_label{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="column-page-path"
                                data-page-builder-target="columnPagePathSelect"
                                data-action="change->page-builder#updateColumnPagePath"
                        >
                            <option value="">{{ 'form.choose'|trans }}</option>
                        </select>
                    </div>
                    <div class="mb-2 d-none" data-page-builder-target="columnFixedPageSelectContainer">
                        <label class="form-label form-label-sm d-block mb-1" for="column-fixed-page">{% trans %}page.builder.inspector.column.link_page_fixed_label{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="column-fixed-page"
                                data-page-builder-target="columnFixedPageSelect"
                                data-action="change->page-builder#updateColumnPagePath"
                        >
                            <option value="">{{ 'form.choose'|trans }}</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1" for="column-height">{% trans %}page.builder.inspector.column.height{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="column-height"
                                data-page-builder-target="columnHeightSelect"
                                data-action="change->page-builder#updateColumnHeight"
                        >
                            <option value="auto">{% trans %}page.builder.inspector.column.height.auto{% endtrans %}</option>
                            <option value="small">{% trans %}page.builder.inspector.column.height.small{% endtrans %}</option>
                            <option value="medium">{% trans %}page.builder.inspector.column.height.medium{% endtrans %}</option>
                            <option value="large">{% trans %}page.builder.inspector.column.height.large{% endtrans %}</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1" for="column-border-radius">{% trans %}page.builder.inspector.column.border_radius{% endtrans %}</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="range"
                                   class="form-range flex-fill"
                                   id="column-border-radius"
                                   min="0"
                                   max="100"
                                   step="1"
                                   value="0"
                                   data-page-builder-target="columnBorderRadiusInput"
                                   data-action="input->page-builder#updateColumnBorderRadius change->page-builder#renderCanvas">
                            <span class="badge bg-secondary" data-page-builder-target="columnBorderRadiusValue">0</span>
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1" for="column-background-type">{% trans %}page.builder.inspector.background_type{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="column-background-type"
                                data-page-builder-target="columnBackgroundTypeSelect"
                                data-action="change->page-builder#updateColumnBackgroundType">
                            <option value="">{% trans %}form.none{% endtrans %}</option>
                            <option value="color">{% trans %}page.builder.inspector.background.color{% endtrans %}</option>
                            <option value="image">{% trans %}page.builder.inspector.background.image{% endtrans %}</option>
                            <option value="class">{% trans %}page.builder.inspector.background.class{% endtrans %}</option>
                        </select>
                    </div>

                    {# Input couleur #}
                    <div class="mb-2 d-none" data-page-builder-target="columnBackgroundColorInput">
                        <label class="form-label form-label-sm d-block mb-1" for="column-bg-color">{% trans %}page.builder.inspector.background.color_label{% endtrans %}</label>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            <button type="button" class="pb-color-preset" style="background-color: #ff007d;" data-color="#ff007d" data-action="click->page-builder#applyColumnColorPreset" title="Rose"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #d6ff00;" data-color="#d6ff00" data-action="click->page-builder#applyColumnColorPreset" title="Jaune"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #00ffae;" data-color="#00ffae" data-action="click->page-builder#applyColumnColorPreset" title="Vert"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #3c001e;" data-color="#3c001e" data-action="click->page-builder#applyColumnColorPreset" title="Rose Sombre"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #000000;" data-color="#000000" data-action="click->page-builder#applyColumnColorPreset" title="Noir"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #ffffff; border: 1px solid #ddd;" data-color="#ffffff" data-action="click->page-builder#applyColumnColorPreset" title="Blanc"></button>
                        </div>
                        <input type="color"
                               class="form-control form-control-lg form-control-color"
                               id="column-bg-color"
                               data-page-builder-target="columnBackgroundColorPicker"
                               data-action="input->page-builder#updateColumnBackgroundValue">
                    </div>

                    <div class="mb-3 d-none" data-page-builder-target="columnBackgroundImageInput">
                        <div class="pb-column-background-image-content">
                            {# Le contenu sera injecté dynamiquement #}
                        </div>
                    </div>

                    <div class="mb-2 d-none" data-page-builder-target="columnBackgroundOverlayInput">
                        <label class="form-label form-label-sm d-block mb-1" for="column-bg-overlay">{% trans %}page.builder.inspector.background.overlay_opacity{% endtrans %}</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="range"
                                   class="form-range flex-fill"
                                   id="column-bg-overlay"
                                   min="0"
                                   max="1"
                                   step="0.1"
                                   value="0"
                                   data-action="input->page-builder#updateColumnBackgroundOverlay">
                            <span class="badge bg-secondary" data-page-builder-target="columnBackgroundOverlayValue">0</span>
                        </div>
                    </div>

                    {# Select classe CSS #}
                    <div class="mb-2 d-none" data-page-builder-target="columnBackgroundClassInput">
                        <label class="form-label form-label-sm d-block mb-1" for="column-bg-class">{% trans %}page.builder.inspector.background.class{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="column-bg-class"
                                data-action="change->page-builder#updateColumnBackgroundValue">
                            <option value="">{% trans %}page.builder.inspector.background.select_class{% endtrans %}</option>
                            <option value="bg-primary">Fond primaire</option>
                            <option value="bg-secondary">Fond secondaire</option>
                            <option value="bg-light">Fond clair</option>
                            <option value="bg-dark">Fond sombre</option>
                        </select>
                    </div>

                </div>
            </div>
        </div>

        {# --- 3. LIGNE (ROW) --- #}
        <div class="accordion-item d-none" data-page-builder-target="inspectorPanelRow">
            <h2 class="accordion-header" id="headingRow">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseRow" aria-expanded="false" aria-controls="collapseRow">
                    {% trans %}page.builder.inspector.row{% endtrans %}
                </button>
            </h2>
            <div id="collapseRow" class="accordion-collapse collapse" aria-labelledby="headingRow" data-bs-parent="#inspectorAccordion">
                <div class="accordion-body">

                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1" for="row-type">{% trans %}page.builder.inspector.row.grid_type{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="row-type"
                                data-page-builder-target="rowTypeSelect"
                                data-action="change->page-builder#updateRowType">
                            <option value="default">{% trans %}form.default{% endtrans %}</option>
                            <option value="icon-box">{% trans %}page.builder.inspector.row.grid_icon{% endtrans %}</option>
                            <option value="ticketing">{% trans %}page.builder.inspector.row.grid_ticketing{% endtrans %}</option>
                            <option value="collapse">{% trans %}page.builder.inspector.row.grid_collapse{% endtrans %}</option>
                        </select>
                    </div>

                    {# Paramètres pour le mode "fixed" #}
                    <div data-page-builder-target="rowFixedParams">
                        <div class="mb-2">
                            <div class="mb-1">
                                <label class="form-label form-label-sm mb-0">{% trans %}page.builder.inspector.row.max_per_row{% endtrans %}</label>
                                <div class="d-flex justify-content-end gap-1 pb-breakpoint-selector">
                                    <button type="button" class="pb-breakpoint-btn active" data-breakpoint="xl" data-action="click->page-builder#changeColumnBreakpoint" title="XL (Ecran)">
                                        <i class="fas fa-desktop"></i>
                                    </button>
                                    <button type="button" class="pb-breakpoint-btn" data-breakpoint="l" data-action="click->page-builder#changeColumnBreakpoint" title="L (Ordinateur portable)">
                                        <i class="fas fa-laptop"></i>
                                    </button>
                                {% if onlyDesktop is not defined or not onlyDesktop %}
                                    <button type="button" class="pb-breakpoint-btn {% if application is defined and application %}active{% endif %}" data-breakpoint="m" data-action="click->page-builder#changeColumnBreakpoint" title="M (Tablette)">
                                        <i class="fas fa-tablet-alt"></i>
                                    </button>
                                    <button type="button" class="pb-breakpoint-btn" data-breakpoint="s" data-action="click->page-builder#changeColumnBreakpoint" title="S (Téléphone)">
                                        <i class="fas fa-mobile-alt"></i>
                                    </button>
                                {% endif %}
                                </div>
                            </div>
                            <div class="pb-columns-editor d-flex gap-1" data-page-builder-target="sectionColumnsEditor">
                                {# rempli en JS #}
                            </div>
                        </div>
                    </div>

                    {# Paramètres pour le mode "auto" #}
                    <div data-page-builder-target="rowAutoParams" class="d-none">
                        <div class="mb-2">
                            <label class="form-label form-label-sm d-block mb-1" for="row-img-width">{% trans %}page.builder.inspector.row.img_width{% endtrans %}</label>
                            <input class="form-control form-control-sm"
                                   placeholder="Ex : 60"
                                   id="row-img-width"
                                   type="number"
                                   data-page-builder-target="rowImgWidthInput"
                                   data-action="change->page-builder#updateRowImgWidth">
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1">{% trans %}page.builder.inspector.row.slider_breakpoint{% endtrans %}</label>
                        <div class="d-flex gap-1 pb-breakpoint-slider-selector" data-page-builder-target="rowSliderSelector">
                            <button type="button" class="pb-breakpoint-btn active" data-breakpoint="none" data-action="click->page-builder#changeRowSliderBreakpoint" title="Aucun">
                                <i class="fas fa-ban"></i>
                            </button>
                            {% if onlyDesktop is not defined or not onlyDesktop %}
                                <button type="button" class="pb-breakpoint-btn" data-breakpoint="s" data-action="click->page-builder#changeRowSliderBreakpoint" title="S (Téléphone)">
                                    <i class="fas fa-mobile-alt"></i>
                                </button>
                                <button type="button" class="pb-breakpoint-btn" data-breakpoint="m" data-action="click->page-builder#changeRowSliderBreakpoint" title="M (Tablette)">
                                    <i class="fas fa-tablet-alt"></i>
                                </button>
                            {% endif %}
                            <button type="button" class="pb-breakpoint-btn" data-breakpoint="l" data-action="click->page-builder#changeRowSliderBreakpoint" title="L (Ordinateur portable)">
                                <i class="fas fa-laptop"></i>
                            </button>
                            <button type="button" class="pb-breakpoint-btn" data-breakpoint="xl" data-action="click->page-builder#changeRowSliderBreakpoint" title="XL (Ecran)">
                                <i class="fas fa-desktop"></i>
                            </button>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1" for="row-align">{% trans %}page.builder.inspector.row.vertical_align{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="row-align" data-action="change->page-builder#updateRowColumnsAlignment">
                            <option value="center" selected>{% trans %}form.center{% endtrans %}</option>
                            <option value="top">{% trans %}page.builder.inspector.row.align_top{% endtrans %}</option>
                            <option value="bottom">{% trans %}page.builder.inspector.row.align_bottom{% endtrans %}</option>
                            <option value="stretch">Stretch</option>
                        </select>
                    </div>

                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1" for="row-justify">{% trans %}page.builder.inspector.row.horizontal_align{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="row-justify" data-action="change->page-builder#updateRowColumnsJustify">
                            <option value="center" selected>{% trans %}form.center{% endtrans %}</option>
                            <option value="space-between">{% trans %}page.builder.inspector.row.space_between{% endtrans %}</option>
                            <option value="space-around">{% trans %}page.builder.inspector.row.space_around{% endtrans %}</option>
                            <option value="flex-start">{% trans %}page.builder.inspector.row.flex_start{% endtrans %}</option>
                            <option value="flex-end">{% trans %}page.builder.inspector.row.flex_end{% endtrans %}</option>
                        </select>
                    </div>
                    {% if (onlyDesktop is not defined or not onlyDesktop) %}
                        <div class="mb-2">
                            <label class="form-label form-label-sm d-block mb-1">{% trans %}page.builder.inspector.row.mobile_behavior{% endtrans %}</label>
                            <div class="d-flex flex-column gap-1">
                                <label class="form-check mb-0">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           data-page-builder-target="rowReverseMobileInput"
                                           data-action="change->page-builder#updateRowResponsive">
                                    <span class="form-check-label ts-normal">{% trans %}page.builder.inspector.row.reverse_mobile{% endtrans %}</span>
                                </label>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# --- 4. SECTION --- #}
        <div class="accordion-item d-none" data-page-builder-target="inspectorPanelSection">
            <h2 class="accordion-header" id="headingSection">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseSection" aria-expanded="true" aria-controls="collapseSection">
                    {% trans %}page.builder.inspector.section{% endtrans %}
                </button>
            </h2>
            <div id="collapseSection" class="accordion-collapse collapse show" aria-labelledby="headingSection" data-bs-parent="#inspectorAccordion">
                <div class="accordion-body">
                    <div class="mb-2">
                        <label class="form-label form-label-sm">{% trans %}page.builder.inspector.section.name{% endtrans %}</label>
                        <input type="text"
                               class="form-control form-control-sm"
                               placeholder="{{ 'page.builder.inspector.section.name_placeholder'|trans }}"
                               data-page-builder-target="sectionNameInput"
                               data-action="input->page-builder#updateSectionName">
                    </div>
                    <div class="mb-2 d-none" data-page-builder-target="sectionActiveContainer">
                        <hr class="mt-3 mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <label class="form-label form-label-sm d-block mb-1">{% trans %}page.builder.inspector.section.status{% endtrans %}</label>
                            <div class="form-check form-switch">
                                <input class="form-check-input mt-0"
                                       type="checkbox"
                                       role="switch"
                                       id="section-active"
                                       data-page-builder-target="sectionActiveInput"
                                       data-action="change->page-builder#updateSectionActive">
                            </div>
                        </div>
                        <hr class="mt-3 mb-3">
                    </div>
                    <div class="mb-2" data-page-builder-target="sectionLayoutContainer">
                        <label class="form-label form-label-sm d-block mb-1" for="section-width">{% trans %}page.builder.inspector.section.width{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="section-width" data-action="change->page-builder#updateSectionLayout">
                            <option value="container-xsmall">x-small</option>
                            <option value="container-small">small</option>
                            <option value="container">medium</option>
                            <option value="container-large">large</option>
                            <option value="container-xlarge">x-large</option>
                            <option value="container-expand">{% trans %}page.builder.inspector.section.width.full{% endtrans %}</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label form-label-sm d-block mb-1" for="section-background-type">{% trans %}page.builder.inspector.background_type{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="section-background-type"
                                data-page-builder-target="sectionBackgroundType"
                                data-action="change->page-builder#updateSectionBackgroundType">
                            <option value="">{% trans %}form.none{% endtrans %}</option>
                            <option value="color">{% trans %}page.builder.inspector.background.color{% endtrans %}</option>
                            <option value="image">{% trans %}page.builder.inspector.background.image{% endtrans %}</option>
                            <option value="class">{% trans %}page.builder.inspector.background.class{% endtrans %}</option>
                        </select>
                    </div>

                    {# Input couleur #}
                    <div class="mb-2 d-none" data-page-builder-target="sectionBackgroundColorInput">
                        <label class="form-label form-label-sm d-block mb-1" for="section-bg-color">{% trans %}page.builder.inspector.background.color_label{% endtrans %}</label>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            <button type="button" class="pb-color-preset" style="background-color: #ff007d;" data-color="#ff007d" data-action="click->page-builder#applySectionColorPreset" title="Rose"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #d6ff00;" data-color="#d6ff00" data-action="click->page-builder#applySectionColorPreset" title="Jaune"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #00ffae;" data-color="#00ffae" data-action="click->page-builder#applySectionColorPreset" title="Vert"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #3c001e;" data-color="#3c001e" data-action="click->page-builder#applySectionColorPreset" title="Rose Sombre"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #000000;" data-color="#000000" data-action="click->page-builder#applySectionColorPreset" title="Noir"></button>
                            <button type="button" class="pb-color-preset" style="background-color: #ffffff; border: 1px solid #ddd;" data-color="#ffffff" data-action="click->page-builder#applySectionColorPreset" title="Blanc"></button>
                        </div>
                        <input type="color"
                               class="form-control form-control-lg form-control-color"
                               id="section-bg-color"
                               data-page-builder-target="sectionBackgroundColorPicker"
                               data-action="input->page-builder#updateSectionBackgroundValue">
                    </div>

                    <div class="mb-3 d-none" data-page-builder-target="sectionBackgroundImageInput">
                        <div class="pb-section-background-image-content">
                            {# Le contenu sera injecté dynamiquement #}
                        </div>
                    </div>

                    {# Select classe CSS #}
                    <div class="mb-2 d-none" data-page-builder-target="sectionBackgroundClassInput">
                        <label class="form-label form-label-sm d-block mb-1" for="section-bg-class">{% trans %}page.builder.inspector.background.class{% endtrans %}</label>
                        <select class="form-select form-select-sm" id="section-bg-class"
                                data-action="change->page-builder#updateSectionBackgroundValue">
                            <option value="">{% trans %}page.builder.inspector.background.select_class{% endtrans %}</option>
                            <option value="bkg-img-secondary">Fond jaune</option>
                            <option value="bkg-paper-bottom-right">Fond jaune avec lettres</option>
                            <option value="bkg-img-third paper-bottom-left">Fond vert avec lettres (gauche)</option>
                            <option value="bkg-img-third paper-top-right">Fond vert avec lettres (droit)</option>
                            <option value="bkg-primary-xdark-color bkg-warmup widget-lineup-list">Fond panthères</option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

    </div>

    {# Inspecteur : Page (Conservé pour rétrocompatibilité ou usage futur) #}
    <section class="pb-section d-none" data-page-builder-target="inspectorPanelPage">
        <div class="pb-section-header">
            <h2 class="pb-section-title" data-page-builder-target="blockTitle">{% trans %}page.builder.inspector.block{% endtrans %}</h2>
        </div>
        <div class="pb-section-body pb-inspector-block-content">
            <div class="mb-2">
                <label class="form-label form-label-sm">{% trans %}page.builder.inspector.block.content{% endtrans %}</label>
                <textarea
                    class="form-control form-control-sm"
                    rows="4"
                    placeholder="{{ 'page.builder.inspector.block.content_placeholder'|trans }}"
                    data-page-builder-target="blockContentInput"
                    data-action="input->page-builder#updateBlockContent"
                ></textarea>
            </div>
        </div>
    </section>

    <div class="mb-3 d-none" id="section-image">
        <label class="form-label form-label-sm">{% trans %}page.builder.inspector.background.image{% endtrans %}</label>
        <div class="d-flex gap-2 align-items-center">
            <div class="panel-list im-manager form-group" data-im-type="image" data-im-entity-class="Aropixel\PageBundle\Entity\Page" data-im-attach-class="Aropixel\PageBundle\Entity\PageBlockImageData" data-im-attach-value="value" data-im-library="Aropixel\PageBundle\Form\Type\DefaultTranslatablePageType" data-im-route="aropixel_page_new">
                <div class="image-widget">
                    <div class="thumbnail" data-im-attach-path="{{ path('image_attach') }}" data-im-attach-class="Aropixel\PageBundle\Entity\PageBlockImageData" data-im-attach-value="value" data-im-attach-id="" data-im-crop-path="" data-im-crops-slugs="" data-im-crops-labels="">
                        <div class="thumb">
                            <div class="preview" data-new="">
                                <span class="thumb-attach no-img v-align-middle"><i class="fas fa-camera"></i></span>
                                <input type="hidden" id="default_translatable_page_image_file_name" name="default_translatable_page[image][file_name]">
                            </div>
                            <div class="caption-overflow">
                                <a data-im-library-trigger="modal" class="iconUpload"></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
