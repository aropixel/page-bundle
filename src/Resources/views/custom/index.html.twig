{% extends '@AropixelAdmin/base.html.twig' %}

{% block asset_manager %}
    {% if aropixel_admin_entry_available %}
        {{ importmap(['@aropixel/admin-bundle', '@aropixel/page-bundle']) }}
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('bundles/aropixelpage/css/page-builder.css') }}">
{% endblock %}

{% block theme_javascripts %}
    <script type="application/json" id="page-json-list-url">
        {{ url('aropixel_custom_page_json_list')|json_encode(constant('JSON_UNESCAPED_SLASHES') b-or constant('JSON_HEX_TAG'))|raw }}
    </script>
    {% if not aropixel_admin_entry_available %}
        <script src="{{ asset('bundles/aropixelpage/js/page_builder_controller.js') }}" type="module"></script>
        <script src="{{ asset('bundles/aropixelpage/js/page_builder_saver_controller.js') }}" type="module"></script>
    {% endif %}
{% endblock %}

{% block body_content %}

    <div id="app">

        {{ include('@AropixelAdmin/Image/Modals/library.html.twig', { 'category' : false }) }}

        <div class="main-wrapper {{ menu_position == "top" ? "container" : "main-wrapper-1" }}">

            {% include '@AropixelAdmin/Menu/fullscreen.html.twig' %}

            {# On ajoute ici le contrôleur 'page-builder-saver' en plus de 'page-builder' #}
            <div
                class="pb-root"
                data-controller="page-builder page-builder-saver"

                data-page-builder-initial-content-value="{{ page ? page.content|json_encode|e('html_attr') : '{}' }}"
                data-page-builder-initial-meta-value="{{ page ? {
                    title: page.title,
                    slug: page.slug,
                    description: page.description,
                    ogImage: page.ogImage
                }|json_encode|e('html_attr') : '{}' }}"

                data-page-builder-saver-save-url-value="{{ path('aropixel_custom_page_save') }}"
                data-page-builder-saver-page-id-value="{{ page ? page.id : '' }}"
            >

            <div class="position-sticky top-0 bg-body mb-3 border-bottom" style="z-index: 1020;">
                <div class="main-content main-content-fullscreen pt-4 pb-3">
                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <h5 class="mb-2">
                            {% if page and page.title %}
                                {{ page.title }}
                            {% else %}
                                Page Builder
                            {% endif %}
                            {% if page %}<small class="text-muted fw-normal ms-2">#{{ page.id }}</small>{% endif %}
                            <span class="ms-2 page-name-editable"
                              style="font-size: 18px; font-weight: 500; color: #9f9f9f; cursor: text; position: relative;"
                              data-page-builder-target="nameDisplay"
                              data-action="click->page-builder#startEditName">
                                <span data-page-builder-target="nameText">
                                    Nouvelle page
                                </span>
                                <i class="fas fa-pen ms-2"></i>
                            </span>
                            <input type="text"
                               class="form-control form-control-lg d-none"
                               data-page-builder-target="nameInput"
                               data-action="blur->page-builder#saveNameEdit keydown->page-builder#handleNameKeydown"
                               style="display: inline-block; width: auto; min-width: 300px;" />
                        </h5>
                        <div class="ms-auto d-none d-md-flex align-items-center gap-2 form-action-btns">

                            <div class="form-switch form-status-switch" style="flex:1">
                                <label class="form-check-label" for="flexSwitchCheckDefault">Publiée</label>
                                <input
                                    class="form-check-input"
                                    type="checkbox"
                                    id="page_status"
                                    name="page[status]"
                                    {{ page and page.status == 'online' ? 'checked' : '' }}
                                    data-page-builder-target="statusField"
                                    data-page-builder-saver-target="paramStatus"
                                    role="switch">
                            </div>

                                <div class="btn-group">
                                    <button class="btn btn-primary btn-small ms-3" id="btnCurrentLocale">FR</button>
                                    <button class="btn btn-primary btn-small dropdown-toggle dropdown-toggle-split" type="button" data-bs-toggle="dropdown"></button>
                                    <div class="dropdown-menu" style="width:80px; min-width: 80px;">
                                        <a class="dropdown-item" href="#" data-action="click->page-builder-saver#switchLocale" data-locale="fr">FR</a>
                                        <div class="dropdown-divider"></div>
                                        <a class="dropdown-item" href="#" data-action="click->page-builder-saver#switchLocale" data-locale="en">EN</a>
                                    </div>
                                </div>

                                <div class="btn-group" role="group">
                                    {# MODIFICATION ICI : L'action pointe vers page-builder-saver #}
                                    <button type="button" class="btn btn-small btn-secondary"
                                            data-action="click->page-builder-saver#save">
                                        <i class="far fa-save me-1"></i> Enregistrer
                                    </button>
                                    <button type="button" class="btn btn-small btn-secondary dropdown-toggle dropdown-toggle-split"
                                            data-bs-toggle="dropdown" aria-expanded="false">
                                        <span class="visually-hidden">Actions</span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center" href="#" data-action="click->page-builder-saver#save">
                                                <i class="fa fa-copy me-1"></i> Enregistrer
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center" href="{{ path('aropixel_custom_page') }}">
                                                <i class="fas fa-file me-1"></i> Nouvelle page
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item d-flex align-items-center" href="{{ path('aropixel_page_index') }}">
                                                <i class="fas fa-list me-1"></i> Retour à la liste
                                            </a>
                                        </li>
                                        {% if page and page.slug %}
                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>
                                            <li>
                                                <a class="dropdown-item d-flex align-items-center" target="_blank" href="{{ path('admin_page_preview', {'slug': page.slug}) }}">
                                                    <i class="fas fa-eye me-1"></i> Accès à la page
                                                </a>
                                            </li>
                                        {% endif %}
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="main-content main-content-fullscreen d-flex justify-content-between align-items-center">
                        <ul class="nav nav-tabs tab-underlined" id="myTab" role="tablist">
                            <li class="nav-item">
                                <a class="nav-link" role="tab" data-bs-toggle="tab" href="#nav-param" id="nav-param-tab">Paramètres de la page</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" role="tab" data-bs-toggle="tab" href="#nav-structure" id="nav-structure-tab">Inspecteur</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link active" role="tab" data-bs-toggle="tab" href="#nav-library" id="nav-library-tab">Contenu</a>
                            </li>
                        </ul>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="syncLocales" checked
                                   data-page-builder-target="syncLocaleInput"
                                   data-action="change->page-builder#shouldSyncToEn">
                            <label class="form-check-label ts-normal" for="syncLocales">
                                Synchroniser version "en" avec "fr"
                            </label>
                        </div>
                    </div>
                </div>

                <div class="main-content main-content-fullscreen">
                    <div class="row g-3">
                        {# Colonne gauche : Sidebar #}
                        <aside class="position-sticky" style="width: 320px; top: 135px; align-self: start;">
                            <div class="tab-content">
                                <div class="tab-pane pt-0 fade" id="nav-param" role="tabpanel" aria-labelledby="nav-param-tab">
                                    {% include '@AropixelPage/custom/_param.html.twig' %}
                                </div>
                                <div class="tab-pane pt-0 fade" id="nav-structure" role="tabpanel" aria-labelledby="nav-structure-tab">
                                    {% include '@AropixelPage/custom/_structure.html.twig' %}
                                </div>
                                <div class="tab-pane pt-0 fade show active" id="nav-library" role="tabpanel" aria-labelledby="nav-library-tab">
                                    {% include '@AropixelPage/custom/_library.html.twig' %}
                                </div>
                            </div>
                        </aside>

                        {# Zone centrale : toolbar + preview #}
                        <main class="col overflow-hidden">
                            <div class="card">
                                <div class="card-header d-flex align-items-center justify-content-between">
                                    <div class="fw-semibold">Prévisualisation</div>
                                    <div class="pb-device-switch">
                                        <button type="button" class="pb-device-switch-btn pb-device-switch-btn--active"
                                                data-page-builder-target="deviceButton" data-device="desktop"
                                                data-action="click->page-builder#switchDevice" title="Vue desktop">
                                            <i class="fas fa-desktop"></i>
                                        </button>
                                        <button type="button" class="pb-device-switch-btn"
                                                data-page-builder-target="deviceButton" data-device="mobile"
                                                data-action="click->page-builder#switchDevice" title="Vue mobile">
                                            <i class="fas fa-mobile-alt"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <section class="pb-canvas-wrapper">
                                        <div class="pb-canvas" data-page-builder-target="canvas">
                                            <div class="pb-canvas-placeholder" data-page-builder-target="canvasPlaceholder">
                                                <p class="pb-empty-state">
                                                    Ajoutez une section ou un template pour commencer à construire la page.
                                                </p>
                                            </div>
                                        </div>
                                    </section>
                                </div>
                            </div>
                        </main>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
