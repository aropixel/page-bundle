{% extends '@AropixelAdmin/List/datatable.html.twig' %}

{% block header_title %}{% trans %}pages.title.description{% endtrans %}{% endblock %}
{% block header_breadcrumb %}
    <ul class="breadcrumb breadcrumb-caret position-right">
        <li class="breadcrumb-item"><a href="{{ url('_admin') }}">{% trans %}text.dashboard{% endtrans %}</a></li>
        <li class="breadcrumb-item active">{% trans %}pages.title{% endtrans %}</li>
    </ul>
{% endblock %}


{% block header_top_right %}
    {% set baseroute = get_baseroute() %}
    {% if route_exists(baseroute ~ '_order') %}
        <a href="{{ path(baseroute ~ '_order') }}" class="btn btn-small btn-default">
            <i class="fas fa-arrows-alt me-2"></i> {% trans %}text.reorder{% endtrans %}
        </a>
    {% endif %}
    {% if app.request.get('_route') != baseroute ~ '_new' and route_exists(baseroute ~ '_new') %}
        <a href="{{ path(baseroute ~ '_new', {'type': type}) }}" class="btn btn-small btn-primary ms-3">
            <i class="fas fa-plus me-2"></i> {% trans %}text.create{% endtrans %}
        </a>
    {% endif %}
{% endblock %}


{% block paneltitle %}{% trans %}page.text.list{% endtrans %}{% endblock %}


{% block paneldatatable %}

    <table class="table card-table table-vcenter text-nowrap datatable">
        <thead>
            <tr>
                <th class="no-sort" style="width: 100px"></th>
                <th>Titre</th>
                <th>Date</th>
                <th class="no-sort" style="width:100px">{% trans %}text.actions{% endtrans %}</th>
            </tr>
        </thead>
        <tbody>

            {% for page in pages %}

                <tr>
                    <td>
                        <a class="position-relative" href="{{ path('aropixel_default_page_edit', {'type': page.type, 'id': page.id}) }}">
                            <img class="img-rounded rounded-3" src="{{ page.image | aropixel_imagine_filter('admin_thumbnail') }}" height="60" />
                            <span class="state-icon img-state-icon state-icon--{{ page.status }}" title="{{ page.status == 'online' ? "status.published"|trans : "status.offline"|trans }}"></span>
                        </a>
                    </td>
                    <td>
                        <a class="d-flex align-items-center" href="{{ path('aropixel_default_page_edit', {'type': page.type, 'id': page.id}) }}">
                            {{ page.title }}
                        </a>
                    </td>
                    <td>{{ page.createdAt|date('d/m/Y') }}</td>
                    <td class="text-right">
                        <div class="btn-group">
                            <button type="button" class="badge badge-light badge-icon" data-bs-toggle="dropdown" data-boundary="viewport">
                                <i class="fas fa-ellipsis-h"></i>
                            </button>
                            <div class="dropdown-menu dropdown-menu-end" data-bs-popper="static">
                                <a href="{{ path('aropixel_default_page_edit', {'type': page.type, 'id': page.id}) }}" class="dropdown-item has-icon"><i class="fas fa-edit"></i> {% trans %}text.edit{% endtrans %}</a>
                                <div class="dropdown-divider"></div>
                                <a data-confirm="{% trans %}pages.list.delete_warning{% endtrans %}" class="delete dropdown-item has-icon text-danger">
                                    <i class="fas fa-trash"></i> {% trans %}form.delete{% endtrans %}
                                </a>
                                <form method="post" action="{{ path('aropixel_page_delete', {'id': page.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete__' ~ page.type ~ '_page' ~ page.id) }}">
                                </form>
                            </div>
                        </div>
                    </td>
                </tr>

            {% endfor %}

        </tbody>
    </table>

{% endblock %}
