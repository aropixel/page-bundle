{% extends '@AropixelPage/base.html.twig' %}

{% block header_title %}Pages{% endblock %}

{% block header_breadcrumb %}
    <ul class="breadcrumb breadcrumb-caret position-right">
        <li class="breadcrumb-item"><a href="{{ url('_admin') }}">Accueil</a></li>
        <li class="breadcrumb-item"><a href="{{ url('aropixel_page_index', {'type': 'default_translatable'}) }}">Pages</a></li>
        {% if page and page.id %}
            <li class="breadcrumb-item active">Modifier</li>
        {% else %}
            <li class="breadcrumb-item active">Création</li>
        {% endif %}
    </ul>
{% endblock %}

{% block tabbable %}
    <li class="nav-item"><a href="#panel-tab1" data-bs-toggle="pill" class="nav-link active"><span>Contenu</span></a></li>
    <li class="nav-item"><a href="#panel-tab2" data-bs-toggle="pill" class="nav-link"><span>Visuel</span></a></li>
    <li class="nav-item"><a href="#panel-tab3" data-bs-toggle="pill" class="nav-link"><span>Référencement</span></a></li>
{% endblock %}

{% block mainPanel %}

    <div class="tab-pane active" id="panel-tab1">

        <div class="card card-centered-large">

            <div class="card-body">

                {{ form_row(form.title) }}
                {{ form_row(form.excerpt) }}
                {{ form_row(form.description) }}

            </div>

        </div>

    </div>

    <div class="tab-pane tab-pane-img" id="panel-tab2">

        <div class="card card-centered-large">

            <div class="card-body">

                {{ form_row(form.image) }}

                <hr>

                <div class="form-group">
                    <div class="d-flex justify-content-between align-items-center mb-2 w-100">
                        <label class="control-label">Citations</label>
                        <a class="btn btn-primary btn-xs" data-form-collection-add="{{ form.testimonials.vars.id }}"><i class="fa fa-plus"></i> Ajouter une citation</a>
                    </div>
                    {{ form_widget(form.testimonials, {'attr': {'class': 'w-100'}}) }}
                </div>

                <hr>

                <div class="form-group">
                    <div class="d-flex justify-content-between align-items-center mb-2 w-100">
                        <label class="control-label">Evènements</label>
                        <a class="btn btn-primary btn-xs" data-form-collection-add="{{ form.events.vars.id }}"><i class="fa fa-plus"></i> Ajouter un évènement</a>
                    </div>
                    {{ form_widget(form.events, {'attr': {'class': 'w-100'}}) }}
                </div>

            </div>

        </div>

    </div>

    <div class="tab-pane" id="panel-tab3">

        <div class="card card-centered-large">

            <div class="card-body">

                {{ form_row(form.metaTitle) }}
                {{ form_row(form.metaDescription) }}
                {{ form_row(form.metaKeywords) }}

            </div>

        </div>

    </div>

{% endblock %}
